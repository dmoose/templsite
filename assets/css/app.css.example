/* Tailwind CSS v4 with DaisyUI Plugin */
@import "tailwindcss";

/* Import DaisyUI plugin (if using) */
/* Uncomment the line below to use DaisyUI components */
/* @plugin "daisyui"; */

/* Custom theme variables */
@theme {
  /* Custom colors */
  --color-brand-50: oklch(0.97 0.01 210);
  --color-brand-100: oklch(0.93 0.03 210);
  --color-brand-200: oklch(0.86 0.06 210);
  --color-brand-300: oklch(0.76 0.09 210);
  --color-brand-400: oklch(0.66 0.12 210);
  --color-brand-500: oklch(0.56 0.15 210);
  --color-brand-600: oklch(0.46 0.12 210);
  --color-brand-700: oklch(0.36 0.09 210);
  --color-brand-800: oklch(0.26 0.06 210);
  --color-brand-900: oklch(0.16 0.03 210);
  --color-brand-950: oklch(0.08 0.01 210);

  /* Typography */
  --font-sans: ui-sans-serif, system-ui, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
  --font-serif: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
  --font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
}

/* Base styles */
@layer base {
  :root {
    /* Set default colors */
    --color-primary: var(--color-brand-500);
    --color-secondary: var(--color-brand-700);
  }

  body {
    @apply antialiased;
  }

  /* Heading styles */
  h1, h2, h3, h4, h5, h6 {
    @apply font-bold;
  }

  h1 {
    @apply text-4xl;
  }

  h2 {
    @apply text-3xl;
  }

  h3 {
    @apply text-2xl;
  }

  /* Link styles */
  a {
    @apply text-blue-600 hover:text-blue-800 transition-colors;
  }

  /* Code blocks */
  pre {
    @apply bg-gray-100 rounded-lg p-4 overflow-x-auto;
  }

  code {
    @apply bg-gray-100 rounded px-1 py-0.5 text-sm font-mono;
  }

  pre code {
    @apply bg-transparent p-0;
  }
}

/* Custom components */
@layer components {
  .btn-primary {
    @apply bg-brand-500 hover:bg-brand-600 text-white font-semibold py-2 px-4 rounded transition-colors;
  }

  .card {
    @apply bg-white rounded-lg shadow-md p-6;
  }

  .container-custom {
    @apply max-w-7xl mx-auto px-4 sm:px-6 lg:px-8;
  }
}

/* Custom utilities */
@layer utilities {
  .text-balance {
    text-wrap: balance;
  }

  .text-pretty {
    text-wrap: pretty;
  }
}
