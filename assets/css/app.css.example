/* Minimal Tailwind CSS v4 with DaisyUI */
@import "tailwindcss";

/* Enable DaisyUI component library
   Provides: card, btn, hero, navbar, drawer, modal, badge, alert, and 30+ more components
   Docs: https://daisyui.com/components/ */
@plugin "daisyui";

/* Custom theme variables (optional)
   Only add these if you need custom brand colors beyond DaisyUI's 30+ built-in themes
   DaisyUI themes: light, dark, cupcake, bumblebee, emerald, corporate, synthwave,
   retro, cyberpunk, valentine, halloween, garden, forest, aqua, lofi, pastel,
   fantasy, wireframe, black, luxury, dracula, cmyk, autumn, business, acid,
   lemonade, night, coffee, winter, dim, nord, sunset */
@theme {
  /* Example: Custom brand color palette
     Use OKLCH for perceptually uniform colors */
  --color-brand-50: oklch(0.97 0.01 210);
  --color-brand-100: oklch(0.93 0.03 210);
  --color-brand-200: oklch(0.86 0.06 210);
  --color-brand-300: oklch(0.76 0.09 210);
  --color-brand-400: oklch(0.66 0.12 210);
  --color-brand-500: oklch(0.56 0.15 210);
  --color-brand-600: oklch(0.46 0.12 210);
  --color-brand-700: oklch(0.36 0.09 210);
  --color-brand-800: oklch(0.26 0.06 210);
  --color-brand-900: oklch(0.16 0.03 210);
  --color-brand-950: oklch(0.08 0.01 210);

  /* Optional: Custom font families */
  --font-sans: ui-sans-serif, system-ui, sans-serif, "Apple Color Emoji", "Segoe UI Emoji";
  --font-mono: ui-monospace, "Cascadia Code", "Source Code Pro", Menlo, Consolas, monospace;
}

/* IMPORTANT: Keep this file minimal!

   ❌ DON'T create custom component classes like:
      @layer components {
        .my-card { @apply bg-white rounded-lg p-4; }
      }

   ✅ DO use DaisyUI components directly in your templ files:
      <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
          <h2 class="card-title">Title</h2>
          <p>Content</p>
          <button class="btn btn-primary">Action</button>
        </div>
      </div>

   The Tailwind CLI automatically scans your templ components and generates
   optimized CSS containing only the classes you actually use.

   DaisyUI provides semantic color tokens that adapt to themes:
   - bg-base-100, bg-base-200, bg-base-300 (backgrounds)
   - text-base-content (text color)
   - border-base-300 (borders)
   - btn-primary, btn-secondary, btn-accent (buttons)

   Change themes by setting data-theme on <html>:
   <html data-theme="dark"> or <html data-theme="cupcake">
*/
