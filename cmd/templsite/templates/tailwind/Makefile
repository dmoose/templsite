# Generated by templsite — edit freely
.DEFAULT_GOAL := help

.PHONY: help build serve deploy prod new-post new-page clean restart

help: ## Show available commands
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-12s\033[0m %s\n", $$1, $$2}'

build: ## Build the site binary
	@templ generate
	@go build -o ./site

serve: build ## Start development server
	@./site serve

deploy: build ## Build static site to public/
	@./site build --env production

prod: build ## Build production site (uses config.production.yaml)
	@./site build --env production

new-post: build ## Create a new blog post (usage: make new-post name=my-title)
	@./site new posts/$(name)

new-page: build ## Create a new page (usage: make new-page name=about)
	@./site new $(name)

clean: ## Remove build artifacts
	@rm -rf public/ site
	@find . -name '*_templ.go' -delete

restart: ## Restart development server
	@pkill -f "./site serve" 2>/dev/null || true
	@sleep 1
	@$(MAKE) serve
