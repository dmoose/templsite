package ui

templ Footer(siteName string) {
	<footer class="footer footer-center p-10 bg-base-200 text-base-content mt-16">
		<aside>
			<p class="font-bold">{ siteName }</p>
			<p>Built with <a href="https://github.com/yourorg/templsite" class="link link-hover">templsite</a></p>
			<p class="text-sm">Copyright © { templ.EscapeString(currentYear()) } - All rights reserved</p>
		</aside>
	</footer>
}

func currentYear() string {
	return "2025"
}
